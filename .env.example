# Ember Configuration

# Server
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8001

# CORS - comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Supabase Auth (required for protected endpoints)
SUPABASE_URL=
SUPABASE_JWT_SECRET=

# NASA FIRMS (required for fire data)
# Get your key at: https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_MAP_KEY=

# Copernicus (optional - for NDVI/NDMI vegetation indices)
# Register at: https://dataspace.copernicus.eu/
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=

# HTTP timeout for external API calls
HTTP_TIMEOUT=30.0

# LANDFIRE COG (optional - faster than REST API)
# Convert LANDFIRE GeoTIFF to COG and upload to S3:
#   python scripts/convert_to_cog.py LC24_F40_250.tif landfire_cog.tif
#   aws s3 cp landfire_cog.tif s3://your-bucket/landfire/fbfm40.tif
LANDFIRE_COG_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2

# STAC (Sentinel-2 scene discovery - no credentials needed)
# Default points to Element 84 Earth Search (free, public)
EARTH_SEARCH_URL=https://earth-search.aws.element84.com/v1

# Full-extent raster overviews (ORQ-140)
# Max output pixel dimension when bbox is omitted; rio-tiler picks the
# closest pyramid overview. Default 1200px balances detail vs payload.
OVERVIEW_MAX_SIZE=1200
# Default search region for no-bbox Sentinel-2 requests.
# Format: min_lon,min_lat,max_lon,max_lat (default: CONUS)
SENTINEL_DEFAULT_REGION=-125,24,-66,50

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text  # text or json
